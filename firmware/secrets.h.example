// Copy this file into each sketch folder as `secrets.h` and fill in.
// `secrets.h` is gitignored; this `.example` is the template that lives in git.
//
// Every sketch needs its own copy — Arduino IDE doesn't look outside the sketch
// folder. The easiest way, from the repo root:
//
//   for d in firmware/*/; do cp -n firmware/secrets.h.example "$d/secrets.h"; done

#pragma once

#define WIFI_SSID  ""
#define WIFI_PASS  ""

// LAN IP of the host running docker compose (Mosquitto). Same for every device.
// Example value below — change it to your server's LAN IP.
#define MQTT_HOST  "10.0.0.88"
