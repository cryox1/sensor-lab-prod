# Copy to .env and fill in. The .env file is gitignored.

POSTGRES_USER=sensors
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=sensors

# Host port the sensor-lab Postgres is published on. Defaults to 5433 (NOT the
# standard 5432) so it can never collide with another PostgreSQL already running
# on the host. Change it if 5433 is also taken. Services inside the compose
# network always reach Postgres at the internal 5432 regardless of this.
POSTGRES_HOST_PORT=5433

# Base dir for DB backups (deploy/backup.sh writes to ${SENSOR_DATA_DIR}/backups).
# Local default is ./data; on a server, point this at a roomy disk, e.g. /mnt/data/sensor-lab.
SENSOR_DATA_DIR=./data

# MQTT (inside compose network)
MQTT_HOST=mosquitto
MQTT_PORT=1883

# Browser-facing API URLs. Leave unset to auto-detect from the page's host
# (works for localhost, LAN IP, and Tailscale name/IP without rebuild).
# Override only if the API lives behind a fixed hostname/reverse proxy.
# WEB_API_BASE=http://api.example.com
# WEB_WS_URL=wss://api.example.com/ws/live
# WEB_API_PORT=8000  # auto-detect uses this port; change if API is on another

# CORS allowed origins for the API (comma-separated). Default "*" matches the
# pre-existing behavior. Tighten to a real host on Tailscale/LAN to lock down
# the rename / hide endpoints.
# CORS_ORIGINS=http://myserver:9530,http://your-host.tailnet.ts.net

# Shared-secret token. If set, PUT endpoints (rename / visibility) require
# header `X-API-Token: <token>`. Unset = endpoints stay open (legacy).
# The frontend reads WEB_API_WRITE_TOKEN -> NEXT_PUBLIC_API_WRITE_TOKEN so the
# browser can include the header. Both must match.
# API_WRITE_TOKEN=change-me-too
# WEB_API_WRITE_TOKEN=change-me-too

# Blitzortung.org live lightning strikes on the /gps map (private,
# non-commercial use; attribution is shown on the map). The feature is OFF
# until HOME_LAT/LON are set — ingest then pulls located strikes within
# BLITZ_RADIUS_KM from the community feed, stores them in Postgres and pushes
# them live to the map.
# BLITZ_HOME_LAT=52.520
# BLITZ_HOME_LON=13.405
# BLITZ_RADIUS_KM=250
# Days to keep strikes (0 = forever).
# BLITZ_RETENTION_DAYS=0
